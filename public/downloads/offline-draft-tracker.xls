<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>Draftastic Offline Draft Tracker</title>
  </head>
  <body>
    <h2>Draftastic Fantasy - Offline Draft Tracker</h2>
    <p>
      Use this worksheet during your offline draft. Fill one row per pick. Suggested flow:
    </p>
    <ol>
      <li>Set draft order (Round 1) before starting.</li>
      <li>During draft, record each pick immediately.</li>
      <li>When finished, go to each team page in Draftastic and add rostered wrestlers.</li>
      <li>Double-check roster totals and male/female requirements before your first scored show.</li>
    </ol>
    <table border="1" cellspacing="0" cellpadding="4">
      <tr>
        <th>Round</th>
        <th>Pick (Overall)</th>
        <th>Team Name</th>
        <th>Manager</th>
        <th>Wrestler</th>
        <th>Brand</th>
        <th>Gender</th>
        <th>Contract Years</th>
        <th>Notes</th>
      </tr>
      <tr><td>1</td><td>1</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>1</td><td>2</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>1</td><td>3</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>1</td><td>4</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>2</td><td>5</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>2</td><td>6</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>2</td><td>7</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>2</td><td>8</td><td></td><td></td><td></td><td></td><td></td><td>3</td><td></td></tr>
      <tr><td>3</td><td>9</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>3</td><td>10</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>3</td><td>11</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>3</td><td>12</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>4</td><td>13</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>4</td><td>14</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>4</td><td>15</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>4</td><td>16</td><td></td><td></td><td></td><td></td><td></td><td>2</td><td></td></tr>
      <tr><td>5</td><td>17</td><td></td><td></td><td></td><td></td><td></td><td>1</td><td></td></tr>
      <tr><td>5</td><td>18</td><td></td><td></td><td></td><td></td><td></td><td>1</td><td></td></tr>
      <tr><td>5</td><td>19</td><td></td><td></td><td></td><td></td><td></td><td>1</td><td></td></tr>
      <tr><td>5</td><td>20</td><td></td><td></td><td></td><td></td><td></td><td>1</td><td></td></tr>
      <tr><td>6</td><td>21</td><td></td><td></td><td></td><td></td><td></td><td>1</td><td></td></tr>
