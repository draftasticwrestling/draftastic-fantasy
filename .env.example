# Copy to .env and fill in. Never commit .env.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Local dev: if Google/email auth sends you to prowrestlingboxscore.com, the Supabase project is shared with
# Boxscore and its "Site URL" is that domain. Fix: Dashboard → Authentication → URL Configuration →
# Redirect URLs — add http://localhost:3000/** (and http://127.0.0.1:3000/** if you use it). Wildcard covers
# /auth/callback?next=... . Production Draftastic URL should be listed too. Site URL can stay the primary prod site.
# Required for creating leagues (server-only; bypasses RLS). From Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL for invite links (e.g. https://draftastic-fantasy.netlify.app/). Leave unset for local dev (defaults to http://localhost:3000).
# NEXT_PUBLIC_APP_URL=https://draftastic-fantasy.netlify.app/

# Optional: send invite emails from the site (Resend). Get key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxx
# From address (optional; default is onboarding@resend.dev). Use a verified domain for production.
# RESEND_FROM_EMAIL=Draftastic Fantasy <invites@yourdomain.com>

# Coming soon landing page uses Constant Contact signup link (hardcoded in EmailSignupForm.tsx).

# League roster from Google Sheets (optional).
# You can paste the normal sheet link (edit URL); the app converts it to CSV export.
# Example: https://docs.google.com/spreadsheets/d/1ETOuez.../edit?gid=1300013357#gid=1300013357
# Or use a direct CSV export URL. Sheet must be viewable by "Anyone with the link" for the app to fetch it.
GOOGLE_SHEET_CSV_URL=

# Wrestler profile full-body images in Supabase Storage. Files: [slug]-full.png
# Option A: Full base URL (recommended). Copy from Supabase Storage → your bucket → get public URL of any file, then remove the filename.
# NEXT_PUBLIC_WRESTLER_FULL_IMAGE_BASE=https://your-project.supabase.co/storage/v1/object/public/your-bucket-name
# Option B: Bucket name only (uses same project as app).
# NEXT_PUBLIC_SUPABASE_WRESTLER_FULL_BUCKET=wrestler-images-full

# Optional: table of title changes (one row per change: championship_type, champion, champion_slug, date).
# If set, current champion and "won" date for the gold box come from the latest row per championship_type.
# Default table name: championship_changes. Set if your table has a different name.
# CHAMPIONSHIP_CHANGES_TABLE=championship_changes

# For Netlify Scheduled Functions: secret passed as x-cron-secret when calling cron routes
# (/api/cron/run-scheduled-drafts, /api/cron/process-trades, /api/cron/recompute-wrestler-stats-cache).
# Set the same value in Netlify env (Site settings → Environment variables).
# CRON_SECRET=your-random-secret

# Optional: max acceptable age of wrestler stats cache (milliseconds) before app falls back to live compute.
# Default is 7 days (604800000). Example below is 24h:
# WRESTLER_STATS_CACHE_MAX_AGE_MS=86400000

# Set to 1 or true to disable all autopick (no cron runs, no runAutoPickIfExpired, no draft polling). Saves serverless usage.
# DISABLE_AUTOPICK_DRAFT=1
