# Copy to .env and fill in. Never commit .env.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Local dev: if Google/email auth sends you to prowrestlingboxscore.com, the Supabase project is shared with
# Boxscore and its "Site URL" is that domain. Fix: Dashboard → Authentication → URL Configuration →
# Redirect URLs — add http://localhost:3000/** (and http://127.0.0.1:3000/** if you use it). Wildcard covers
# /auth/callback?next=... . Production Draftastic URL should be listed too. Site URL can stay the primary prod site.
# Required for creating leagues (server-only; bypasses RLS). From Dashboard → Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI for local backups (./scripts/supabase-pgdump.sh). Dashboard → Settings → Database →
# Connection string → URI. Use Session mode or Direct (not Transaction pooler). Never commit this line filled in.
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# Base URL for invite links (e.g. https://draftastic-fantasy.netlify.app/). Leave unset for local dev (defaults to http://localhost:3000).
# NEXT_PUBLIC_APP_URL=https://draftastic-fantasy.netlify.app/

# Canonical site URL for SEO: Open Graph, metadataBase, sitemap, and JSON-LD (no trailing slash).
# Production: https://draftasticprowrestling.com — set in Netlify env so previews still use deploy URL when unset.
# NEXT_PUBLIC_SITE_URL=https://draftasticprowrestling.com

# Beta: restrict who can use "Create a league". Comma-separated secrets (server-only). If unset or empty, anyone
# signed in can create a league. Set in production (e.g. Netlify) to codes you share with mailing-list testers.
# LEAGUE_CREATION_ACCESS_CODES=your-first-code,your-second-code
# Site admins (profiles.is_site_admin) skip the mailing-list code and can create any league format / 3–16 teams.

# Optional: send invite emails from the site via Resend HTTP API (/api/leagues/invite/send).
# Supabase Auth emails (confirm signup, password reset) use Resend too, but are configured in the
# Supabase Dashboard → Authentication → SMTP (same API key as SMTP password). See docs/RESEND_SUPABASE_AUTH.md
# RESEND_API_KEY=re_xxxx
# From address on your verified domain (optional; default onboarding@resend.dev — not for production).
# RESEND_FROM_EMAIL=Draftastic Fantasy <invites@yourdomain.com>

# Constant Contact landing page URL is used by CTA links in the UI.
# Constant Contact API (optional): sync explicit account opt-ins directly into your list.
# CONSTANT_CONTACT_ACCESS_TOKEN=eyJ...  (JWT from token response — NOT the short refresh_token)
# CONSTANT_CONTACT_REFRESH_TOKEN=...   (optional; for npm run cc:refresh-token when access expires)
# CONSTANT_CONTACT_LIST_ID=your-list-id
# List UUIDs: npm run cc:list-ids  (reads token from .env; easier than curl with long Bearer tokens)
# Optional override; default is https://api.cc.email/v3
# CONSTANT_CONTACT_API_BASE=https://api.cc.email/v3
#
# OAuth (one-time token setup): register this EXACT redirect URI in the CC Developer Portal, then:
# Use the real API key from Developer Portal → My Applications (do not leave the literal "your-..." placeholder text).
# If `next dev` prints "using port 3002" (etc.), use that port in BOTH .env and the portal redirect list.
# CONSTANT_CONTACT_CLIENT_ID=your-app-client-id
# Must match Developer Portal redirect list exactly (path + trailing slash). Examples:
# CONSTANT_CONTACT_OAUTH_REDIRECT_URI=http://localhost:3000/callback
# CONSTANT_CONTACT_OAUTH_REDIRECT_URI=https://YOUR-SITE.netlify.app/
# CONSTANT_CONTACT_OAUTH_REDIRECT_URI=https://YOUR-SITE.netlify.app/constant-contact-callback
# Open /constant-contact/oauth on your site to start OAuth (avoids hand-encoding the authorize URL).
# Optional: CONSTANT_CONTACT_OAUTH_SCOPE=contact_data offline_access

# League roster from Google Sheets (optional).
# You can paste the normal sheet link (edit URL); the app converts it to CSV export.
# Example: https://docs.google.com/spreadsheets/d/1ETOuez.../edit?gid=1300013357#gid=1300013357
# Or use a direct CSV export URL. Sheet must be viewable by "Anyone with the link" for the app to fetch it.
GOOGLE_SHEET_CSV_URL=

# Wrestler profile full-body images in Supabase Storage. Files: [slug]-full.png
# Option A: Full base URL (recommended). Copy from Supabase Storage → your bucket → get public URL of any file, then remove the filename.
# NEXT_PUBLIC_WRESTLER_FULL_IMAGE_BASE=https://your-project.supabase.co/storage/v1/object/public/your-bucket-name
# Option B: Bucket name only (uses same project as app).
# NEXT_PUBLIC_SUPABASE_WRESTLER_FULL_BUCKET=wrestler-images-full

# Optional: table of title changes (one row per change: championship_type, champion, champion_slug, date).
# If set, current champion and "won" date for the gold box come from the latest row per championship_type.
# Default table name: championship_changes. Set if your table has a different name.
# CHAMPIONSHIP_CHANGES_TABLE=championship_changes

# For Netlify Scheduled Functions: secret passed as x-cron-secret when calling cron routes
# (/api/cron/run-scheduled-drafts, /api/cron/process-trades, /api/cron/recompute-wrestler-stats-cache).
# Set the same value in Netlify env (Site settings → Environment variables).
# CRON_SECRET=your-random-secret

# Optional: max acceptable age of wrestler stats cache (milliseconds) before app falls back to live compute.
# Default is 7 days (604800000). Example below is 24h:
# WRESTLER_STATS_CACHE_MAX_AGE_MS=86400000

# Set to 1 or true to disable all autopick (no cron runs, no runAutoPickIfExpired, no draft polling). Saves serverless usage.
# DISABLE_AUTOPICK_DRAFT=1

# --- Google AdSense / Search Console ---
# AdSense script loads only in production unless you set NEXT_PUBLIC_ADSENSE_DEV=1 (avoids localhost noise).
# NEXT_PUBLIC_ADSENSE_DEV=1
# Optional: override publisher id (default matches app/layout historical ca-pub).
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# Disable all AdSense script + units (emergency).
# NEXT_PUBLIC_ADSENSE_DISABLE=1
# After creating Display ad units in AdSense, paste numeric slot ids so units render on public pages:
# NEXT_PUBLIC_ADSENSE_SLOT_HUB_HOME=1234567890
# NEXT_PUBLIC_ADSENSE_SLOT_FANTASY=1234567890
# Search Console → HTML tag verification: paste content value only (not the whole meta tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
